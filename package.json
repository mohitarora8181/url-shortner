{
  "name": "url-shortner-backend",
  "version": "1.0.0",
  "description": "Modular URL shortener backend with authentication, MongoDB persistence, and Redis caching.",
  "main": "dist/main.js",
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nest start --watch",
    "deps:up": "docker compose up -d mongo redis",
    "deps:down": "docker compose down",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck"
  },
  "keywords": [
    "url-shortener",
    "nestjs",
    "mongodb",
    "redis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.24",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^16.4.7",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "@nestjs/cli": "^11.0.21",
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "rxjs": "^7.8.2"
  }
}
